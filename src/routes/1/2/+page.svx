        }
        if (!beeperAt33 || beeperAt33.count === 0) {
          return { passed: false, message: 'There should be 2 beepers at position (3, 3).' };
        }
        if (beeperAt33.count === 1) {
          return { passed: false, message: 'Only 1 beeper at (3, 3) — you need to deliver both!' };
        }
        return { passed: false, message: 'Something isn\'t right. Make sure both beepers end up at (3, 3) and nowhere else.' };
