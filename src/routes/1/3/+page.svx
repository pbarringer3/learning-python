<script lang="ts">
  import LessonShell from '$lib/components/LessonShell.svelte';
  import KarelEnvironment from '$lib/components/KarelEnvironment.svelte';
  import type { KarelConfig } from '$lib/karel/types';

  // Example: Building a tower with decomposition
  const towerExample: KarelConfig = {
    initialWorld: {
      dimensions: { width: 5, height: 5 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Build a tower of 3 beepers at column 3
# Notice how each function handles ONE clear task.

def move_to_column_three():
  move()
  move()

def build_tower():
  turn_left()
  put_beeper()
  move()
  put_beeper()
  move()
  put_beeper()

# Main program — reads like a plan!
move_to_column_three()
build_tower()
`
  };

  // Example 2: Decomposing a complex task
  const houseExample: KarelConfig = {
    initialWorld: {
      dimensions: { width: 7, height: 5 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Place beepers along the bottom from (2,1) to (6,1),
# then build a column at (6,1) to (6,3).
# This makes an L-shape!

def build_base():
  move()
  put_beeper()
  move()
  put_beeper()
  move()
  put_beeper()
  move()
  put_beeper()
  move()
  put_beeper()

def build_column():
  turn_left()
  move()
  put_beeper()
  move()
  put_beeper()

# Main program
build_base()
build_column()
`
  };

  // Exercise 1: Decorate the corners
  const exercise1Config: KarelConfig = {
    persistenceKey: '1/3/exercise-1',
    initialWorld: {
      dimensions: { width: 5, height: 5 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Place one beeper in each corner of the 5x5 world:
# (1,1), (5,1), (5,5), and (1,5).
#
# Decompose: what's the repeated pattern?

`,
    allowedFeatures: {
      karelCommands: ['move', 'turn_left', 'put_beeper']
    },
    tests: {
      worlds: {
        'Main Test': {
          dimensions: { width: 5, height: 5 },
          karel: {
            position: { x: 1, y: 1 },
            direction: { type: 'east' },
            beepers: -1
          },
          walls: [],
          beepers: []
        }
      },
      validate: (world) => {
        const corners = [
          { x: 1, y: 1 },
          { x: 5, y: 1 },
          { x: 5, y: 5 },
          { x: 1, y: 5 }
        ];
        const missing = corners.filter(
          (c) => !world.beepers.find((b) => b.x === c.x && b.y === c.y && b.count > 0)
        );

        if (missing.length === 0) {
          return { passed: true, message: 'All four corners decorated! Great decomposition!' };
        }
        const missingStr = missing.map((c) => `(${c.x}, ${c.y})`).join(', ');
        return {
          passed: false,
          message: `Missing beepers at: ${missingStr}`
        };
      }
    }
  };

  // Exercise 2: Build a plus sign
  const exercise2Config: KarelConfig = {
    persistenceKey: '1/3/exercise-2',
    initialWorld: {
      dimensions: { width: 5, height: 5 },
      karel: {
        position: { x: 3, y: 1 },
        direction: { type: 'north' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Build a plus (+) sign centered at (3, 3).
# Place beepers at:
#   (3,1), (3,2), (3,3), (3,4), (3,5)  — vertical bar
#   (1,3), (2,3), (3,3), (4,3), (5,3)  — horizontal bar
#
# Karel starts at (3, 1) facing north.
# Break this into smaller functions!

`,
    allowedFeatures: {
      karelCommands: ['move', 'turn_left', 'put_beeper']
    },
    tests: {
      worlds: {
        'Main Test': {
          dimensions: { width: 5, height: 5 },
          karel: {
            position: { x: 3, y: 1 },
            direction: { type: 'north' },
            beepers: -1
          },
          walls: [],
          beepers: []
        }
      },
      validate: (world) => {
        const required = [
          { x: 3, y: 1 }, { x: 3, y: 2 }, { x: 3, y: 3 }, { x: 3, y: 4 }, { x: 3, y: 5 },
          { x: 1, y: 3 }, { x: 2, y: 3 }, { x: 4, y: 3 }, { x: 5, y: 3 }
        ];
        const missing = required.filter(
          (r) => !world.beepers.find((b) => b.x === r.x && b.y === r.y && b.count > 0)
        );

        if (missing.length === 0) {
          return { passed: true, message: 'Beautiful plus sign! Excellent decomposition work!' };
        }
        return {
          passed: false,
          message: `${missing.length} beeper(s) missing from the plus pattern. Check your positioning carefully.`
        };
      }
    }
  };

  // Exercise 3: Collect Newspaper
  const exercise3Config: KarelConfig = {
    persistenceKey: '1/3/exercise-3',
    initialWorld: {
      dimensions: { width: 5, height: 5 },
      karel: {
        position: { x: 4, y: 5 },
        direction: { type: 'south' },
        beepers: 0
      },
      walls: [
        { type: 'vertical', x: 3, y: 4 },
        { type: 'vertical', x: 3, y: 5 },
        { type: 'horizontal', x: 5, y: 4 }
      ],
      beepers: [{ x: 2, y: 1, count: 1 }]
    },
    initialCode: `# You must define and call these two functions:
#
# move_to_paper()
#   Pre:  Karel is at (4, 5) facing south
#   Post: Karel is at (2, 1) facing west
#
# return_to_start()
#   Pre:  Karel is at (2, 1) facing west
#   Post: Karel is at (4, 5) facing south
#
# You may also create additional helper functions.
`,
    allowedFeatures: {
      karelCommands: ['move', 'turn_left', 'pick_beeper']
    },
    tests: {
      worlds: {
        'Collect newspaper and return home': {
          dimensions: { width: 5, height: 5 },
          karel: {
            position: { x: 4, y: 5 },
            direction: { type: 'south' },
            beepers: 0
          },
          walls: [
            { type: 'vertical', x: 3, y: 4 },
            { type: 'vertical', x: 3, y: 5 },
            { type: 'horizontal', x: 5, y: 4 }
          ],
          beepers: [{ x: 2, y: 1, count: 1 }]
        }
      },
      validate: (world) => {
        const newspaperStillThere = world.beepers.find(
          (b) => b.x === 2 && b.y === 1 && b.count > 0
        );
        if (newspaperStillThere) {
          return { passed: false, message: 'Karel needs to pick up the newspaper at (2, 1)!' };
        }

        const { x, y } = world.karel.position;
        if (x !== 4 || y !== 5) {
          return {
            passed: false,
            message: `Karel should return to (4, 5) but ended up at (${x}, ${y}).`
          };
        }

        return {
          passed: true,
          message: 'Karel collected the newspaper and returned home! Great decomposition!'
        };
      },
      validateCode: {
        name: 'Defined and called both required functions',
        validate: (code) => {
        const definesMoveToPaper = /def\s+move_to_paper\s*\(/.test(code);
        const definesReturnToStart = /def\s+return_to_start\s*\(/.test(code);
        const callsMoveToPaper = code.split('\n').some(
          (line) => /^\s*move_to_paper\s*\(/.test(line) && !/^\s*def\s/.test(line)
        );
        const callsReturnToStart = code.split('\n').some(
          (line) => /^\s*return_to_start\s*\(/.test(line) && !/^\s*def\s/.test(line)
        );

        const missing: string[] = [];
        if (!definesMoveToPaper) missing.push('define move_to_paper()');
        if (!definesReturnToStart) missing.push('define return_to_start()');
        if (definesMoveToPaper && !callsMoveToPaper) missing.push('call move_to_paper()');
        if (definesReturnToStart && !callsReturnToStart) missing.push('call return_to_start()');

        if (missing.length > 0) {
          return {
            passed: false,
            message: `You must ${missing.join(' and ')}. See the requirements above.`
          };
        }
        return { passed: true, message: '' };
        }
      },
      functionTests: [
        {
          name: 'move_to_paper() moves Karel to (2, 1)',
          functionName: 'move_to_paper',
          world: {
            dimensions: { width: 5, height: 5 },
            karel: {
              position: { x: 4, y: 5 },
              direction: { type: 'south' },
              beepers: 0
            },
            walls: [
              { type: 'vertical', x: 3, y: 4 },
              { type: 'vertical', x: 3, y: 5 },
              { type: 'horizontal', x: 5, y: 4 }
            ],
            beepers: [{ x: 2, y: 1, count: 1 }]
          },
          validate: (world) => {
            const { x, y } = world.karel.position;
            if (x !== 2 || y !== 1) {
              return {
                passed: false,
                message: `move_to_paper() should move Karel to (2, 1) but Karel ended up at (${x}, ${y}).`
              };
            }
            return { passed: true, message: 'move_to_paper() correctly moves Karel to the newspaper!' };
          }
        },
        {
          name: 'return_to_start() brings Karel back to (4, 5)',
          functionName: 'return_to_start',
          world: {
            dimensions: { width: 5, height: 5 },
            karel: {
              position: { x: 2, y: 1 },
              direction: { type: 'west' },
              beepers: 0
            },
            walls: [
              { type: 'vertical', x: 3, y: 4 },
              { type: 'vertical', x: 3, y: 5 },
              { type: 'horizontal', x: 5, y: 4 }
            ],
            beepers: []
          },
          validate: (world) => {
            const { x, y } = world.karel.position;
            if (x !== 4 || y !== 5) {
              return {
                passed: false,
                message: `return_to_start() should bring Karel back to (4, 5) from (2, 1) but Karel ended up at (${x}, ${y}).`
              };
            }
            return { passed: true, message: 'return_to_start() correctly brings Karel home!' };
          }
        }
      ]
    }
  };
</script>

