  // Example 2: Decomposing a complex task
  const houseExample: KarelConfig = {
    initialWorld: {
      dimensions: { width: 7, height: 5 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Place beepers along the bottom from (2,1) to (6,1),
# then build a column at (6,1) to (6,3).
# This makes an L-shape!

def turn_right():
    turn_left()
    turn_left()
    turn_left()

def turn_around():
    turn_left()
    turn_left()

def build_base():
    move()
    put_beeper()
    move()
    put_beeper()
    move()
    put_beeper()
    move()
    put_beeper()
    move()
    put_beeper()

def build_column():
    turn_left()
    move()
    put_beeper()
    move()
    put_beeper()

# Main program
build_base()
build_column()
`
  };

  // Exercise 1: Decorate the corners
  const exercise1Config: KarelConfig = {
    initialWorld: {
      dimensions: { width: 5, height: 5 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Place one beeper in each corner of the 5x5 world:
# (1,1), (5,1), (5,5), and (1,5).
#
# Decompose: what's the repeated pattern?
# Hint: "place a beeper, move to the next corner" is one step.

`,
    allowedFeatures: {
      karelCommands: ['move', 'turn_left', 'put_beeper']
    },
    tests: {
      worlds: {
        'Main Test': {
          dimensions: { width: 5, height: 5 },
          karel: {
            position: { x: 1, y: 1 },
            direction: { type: 'east' },
            beepers: -1
          },
          walls: [],
          beepers: []
        }
      },
      validate: (world) => {
        const corners = [
          { x: 1, y: 1 },
          { x: 5, y: 1 },
          { x: 5, y: 5 },
          { x: 1, y: 5 }
        ];
        const missing = corners.filter(
          (c) => !world.beepers.find((b) => b.x === c.x && b.y === c.y && b.count > 0)
        );

        if (missing.length === 0) {
          return { passed: true, message: 'All four corners decorated! Great decomposition!' };
        }
        const missingStr = missing.map((c) => `(${c.x}, ${c.y})`).join(', ');
        return {
          passed: false,
          message: `Missing beepers at: ${missingStr}`
        };
      }
    }
  };

  // Exercise 2: Build a plus sign
  const exercise2Config: KarelConfig = {
    initialWorld: {
      dimensions: { width: 5, height: 5 },
