  // Example 1: Place beepers in a row
  const rowExample: KarelConfig = {
    initialWorld: {
      dimensions: { width: 6, height: 1 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Place 5 beepers in a row.
# for i in range(5) repeats the indented code 5 times.

for i in range(5):
    put_beeper()
    move()
`
  };

  // Example 2: Efficient turn_right with for loop
  const turnRightForExample: KarelConfig = {
    initialWorld: {
      dimensions: { width: 5, height: 5 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# A cleaner way to write turn_right()!
def turn_right():
    for i in range(3):
        turn_left()

# Use it to trace a square path,
# placing a beeper at each corner.
for i in range(4):
    put_beeper()
    move()
    move()
    turn_right()
`
  };

  // Exercise 1: Place beepers at every position in a row
  const exercise1Config: KarelConfig = {
    persistenceKey: '1/5/exercise-1',
    initialWorld: {
      dimensions: { width: 5, height: 1 },
      karel: {
        position: { x: 1, y: 1 },
        direction: { type: 'east' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Place a beeper at EVERY position in the row,
# including Karel's starting spot and the very end.
#
# The world is 5 cells wide.

`,
    allowedFeatures: {
      karelCommands: [
        'move', 'turn_left', 'put_beeper', 'pick_beeper',
        'front_is_clear', 'front_is_blocked'
      ]
    },
    tests: {
      worlds: {
        'Main Test': {
          dimensions: { width: 5, height: 1 },
          karel: {
            position: { x: 1, y: 1 },
            direction: { type: 'east' },
            beepers: -1
          },
          walls: [],
          beepers: []
        }
      },
      validate: (world) => {
        const width = world.dimensions.width;
        const missing = [];
        for (let x = 1; x <= width; x++) {
          const b = world.beepers.find((b) => b.x === x && b.y === 1 && b.count > 0);
          if (!b) missing.push(x);
        }
        if (missing.length === 0) {
          return { passed: true, message: 'Every position has a beeper! Well done.' };
        }
        return {
          passed: false,
          message: `Missing beepers at column(s): ${missing.join(', ')}. Remember to cover both ends!`
        };
      }
    }
  };

  // Exercise 2: Build a tower
  const exercise2Config: KarelConfig = {
    persistenceKey: '1/5/exercise-2',
    initialWorld: {
      dimensions: { width: 5, height: 5 },
      karel: {
        position: { x: 3, y: 1 },
        direction: { type: 'north' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Build a tower: place a beeper at every position
# in column 3, from (3,1) to (3,5).
#
# Karel starts at (3, 1) facing north.
# Use a for loop!

`,
    allowedFeatures: {
      karelCommands: [
        'move', 'turn_left', 'put_beeper', 'pick_beeper',
        'front_is_clear', 'front_is_blocked'
      ]
    },
    tests: {
      worlds: {
        'Main Test': {
          dimensions: { width: 5, height: 5 },
          karel: {
            position: { x: 3, y: 1 },
            direction: { type: 'north' },
            beepers: -1
          },
          walls: [],
          beepers: []
        }
      },
      validate: (world) => {
        const missing = [];
        for (let y = 1; y <= 5; y++) {
          const b = world.beepers.find((b) => b.x === 3 && b.y === y && b.count > 0);
          if (!b) missing.push(y);
        }
        if (missing.length === 0) {
          return { passed: true, message: 'Tower complete! 5 beepers stacked in column 3.' };
        }
        return {
          passed: false,
          message: `Missing beepers at row(s): ${missing.join(', ')} in column 3.`
        };
      }
    }
  };

  // Exercise 3: Build a diamond outline
  const exercise3Config: KarelConfig = {
    persistenceKey: '1/5/exercise-3',
    initialWorld: {
      dimensions: { width: 3, height: 3 },
      karel: {
        position: { x: 2, y: 1 },
        direction: { type: 'north' },
        beepers: -1
      },
      walls: [],
      beepers: []
    },
    initialCode: `# Place beepers around the edges of this 3x3 world.
# That means every cell on the border:
# Bottom: (1,1), (2,1), (3,1)
# Right:  (3,2), (3,3)
# Top:    (2,3), (1,3)
# Left:   (1,2)
#
# Karel starts at (2, 1) facing north.
# Use for loops and functions to keep it clean!

def turn_right():
    for i in range(3):
        turn_left()

`,
    allowedFeatures: {
      karelCommands: [
        'move', 'turn_left', 'put_beeper', 'pick_beeper',
        'front_is_clear', 'front_is_blocked'
      ]
    },
    tests: {
      worlds: {
        'Main Test': {
          dimensions: { width: 3, height: 3 },
          karel: {
            position: { x: 2, y: 1 },
            direction: { type: 'north' },
            beepers: -1
          },
          walls: [],
          beepers: []
        }
      },
      validate: (world) => {
        const border = [
          { x: 1, y: 1 }, { x: 2, y: 1 }, { x: 3, y: 1 },
          { x: 3, y: 2 }, { x: 3, y: 3 },
          { x: 2, y: 3 }, { x: 1, y: 3 },
          { x: 1, y: 2 }
        ];
        const missing = border.filter(
          (r) => !world.beepers.find((b) => b.x === r.x && b.y === r.y && b.count > 0)
        );
        if (missing.length === 0) {
          return { passed: true, message: 'Border complete! Great use of for loops.' };
        }
        return {
          passed: false,
          message: `${missing.length} border position(s) missing beepers.`
        };
      }
    }
  };
</script>

